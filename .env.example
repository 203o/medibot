PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/medibot?retryWrites=true&w=majority&appName=medibot
FASTAPI_INGESTION_URL=http://127.0.0.1:8001
INGESTION_MAX_RESULTS=40
INGESTION_SOURCE_FETCH_K=20
FAISS_TOP_K=40
RANKED_DOC_K=40
SURFACED_EVIDENCE_K=8
OPENALEX_SPARSE_THRESHOLD=12
ENABLE_LLM_QUERY_EXPANSION=false
QUERY_EXPANSION_MAX=3
QUERY_EXPANSION_TIMEOUT_SEC=8
LLM_QUERY_EXPANSION_CONDITIONAL=true
HF_QUERY_EXPANSION_MODEL=meta-llama/Llama-3.1-8B-Instruct
HF_TOKEN=
LLM_CHAT_PROVIDER=huggingface
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
ENABLE_LLM_SEMANTIC_CLASSIFIER=false
LLM_CLASSIFY_MAX_DOCS=8
HF_SEMANTIC_MODEL=meta-llama/Llama-3.1-8B-Instruct
ENABLE_UNIFIED_REASONING_HEAD=true
ENABLE_LLM_TIERED_SYNTHESIS=true
STRICT_LLM_CHAT=false
CHAT_TONE_MODE=clinical
HF_SYNTHESIS_MODEL=meta-llama/Llama-3.1-8B-Instruct
HF_SYNTHESIS_MODEL_FALLBACKS=Qwen/Qwen2.5-7B-Instruct
LLM_SYNTHESIS_MAX_CHUNKS=6
LLM_SYNTHESIS_MAX_TOKENS=700
LLM_SYNTHESIS_TITLE_CHARS=110
LLM_SYNTHESIS_SUMMARY_CHARS=180
LLM_SYNTHESIS_HTTP_TIMEOUT_MS=25000
LLM_SYNTHESIS_TOTAL_ATTEMPTS=2
LLM_SYNTHESIS_RETRY_BACKOFF_MS=800
LLM_SYNTHESIS_ALLOW_AGGRESSIVE_RETRY=false
LLM_SEMANTIC_TIMEOUT_SEC=15
FOLLOWUP_REUSE_MIN_MATCHED=5
FOLLOWUP_REUSE_MIN_COVERAGE=0.35
FAISS_INDEX_NAME=medibot-evidence
FAISS_NAMESPACE=pubmed-ai
FAISS_STORAGE_DIR=data/faiss
FAISS_ENABLED=true
PUBMED_TOOL=medibot
PUBMED_EMAIL=you@example.com
